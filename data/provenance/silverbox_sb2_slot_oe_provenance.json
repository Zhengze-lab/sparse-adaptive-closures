  "parameterization": {
    "c": "positive damping, c=exp(log_c)",
    "beta0": "positive linear stiffness component, beta0=exp(log_beta0)",
    "beta2": "signed cubic stiffness component, beta2=beta2_scale*beta2_scaled",
